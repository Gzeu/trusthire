generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Assessment {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  sessionId     String
  recruiterName String
  company       String
  finalScore    Int
  verdict       String
  inputData     String   // JSON stored as string
  scoreData     String   // JSON stored as string
  redFlags      String   // JSON stored as string
  vtResults     String?  // JSON stored as string
  repoScans     String?  // JSON stored as string
  shareToken    String   @unique @default(cuid())

  @@index([sessionId])
  @@index([shareToken])
}

model ScamPattern {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  category    String
  description String
  indicators  String   // JSON array stored as string
  ecosystem   String
  verified    Boolean  @default(false)
  anonymous   Boolean  @default(true)
}
