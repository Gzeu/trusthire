generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Assessment {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  sessionId     String
  recruiterName String
  company       String
  finalScore    Int
  verdict       String
  inputData     Json
  scoreData     Json
  redFlags      Json
  vtResults     Json?
  repoScans     Json?
  shareToken    String   @unique @default(cuid())

  @@index([sessionId])
  @@index([shareToken])
}

model ScamPattern {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  category    String
  description String
  indicators  String[]
  ecosystem   String
  verified    Boolean  @default(false)
  anonymous   Boolean  @default(true)
}
