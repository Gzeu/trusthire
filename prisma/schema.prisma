generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Assessment {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  sessionId     String
  recruiterName String
  company       String
  finalScore    Int
  verdict       String
  inputData     String   // JSON stored as string
  scoreData     String   // JSON stored as string
  redFlags      String   // JSON stored as string
  vtResults     String?  // JSON stored as string
  repoScans     String?  // JSON stored as string
  shareToken    String   @unique @default(cuid())

  @@index([sessionId])
  @@index([shareToken])
}

model ScamPattern {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  category    String
  description String
  indicators  String   // JSON array stored as string
  ecosystem   String
  verified    Boolean  @default(false)
  anonymous   Boolean  @default(true)
}

model ScamReport {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  status        String    @default("pending") // pending / approved / rejected
  reporterIp    String
  recruiterName String
  company       String
  evidence      String    // text
  category      String    // fake_job / malicious_repo / phishing_domain / scam_payment / other
  resolvedAt    DateTime?
  resolvedBy    String?

  @@index([status])
}

model Blacklist {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  type        String   // domain / email / repo / github_user
  value       String
  reason      String
  addedBy     String
  reportCount Int      @default(1)

  @@index([type, value])
}
