generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Assessment {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  sessionId     String
  recruiterName String
  company       String
  finalScore    Int
  verdict       String
  inputData     String   // JSON stored as string
  scoreData     String   // JSON stored as string
  redFlags      String   // JSON stored as string
  vtResults     String?  // JSON stored as string
  repoScans     String?  // JSON stored as string
  shareToken    String   @unique @default(cuid())

  @@index([sessionId])
  @@index([shareToken])
}

model ScamPattern {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  category    String
  description String
  indicators  String   // JSON array stored as string
  ecosystem   String
  verified    Boolean  @default(false)
  anonymous   Boolean  @default(true)
}

model ScamReport {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  status        String    @default("pending") // pending / approved / rejected
  reporterIp    String
  recruiterName String
  company       String
  evidence      String    // text
  category      String    // fake_job / malicious_repo / phishing_domain / scam_payment / other
  resolvedAt    DateTime?
  resolvedBy    String?

  @@index([status])
}

model Blacklist {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  type        String   // domain / email / repo / github_user
  value       String
  reason      String
  addedBy     String
  reportCount Int      @default(1)

  @@index([type, value])
}

// Scan History and Analytics Models
model ScanHistory {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?  // Optional user ID when authentication is implemented
  sessionId       String   // Session identifier for anonymous users
  scanType        String   // github, url, linkedin, forms
  target          String   // Repository URL, website URL, etc.
  status          String   @default("pending") // pending, running, completed, failed
  overallScore    Int?     // Overall risk/trust score
  scanDuration   Int?     // Scan duration in milliseconds
  resultData      String   // JSON with all scan results
  errorData       String?  // JSON with error information
  metadata        String?  // JSON with additional metadata
  ipAddress       String?  // User IP for analytics
  userAgent       String?  // User agent for analytics
  
  @@index([userId])
  @@index([sessionId])
  @@index([scanType])
  @@index([status])
  @@index([createdAt])
}

model UserAnalytics {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?  // Optional user ID when authentication is implemented
  sessionId       String   // Session identifier for anonymous users
  eventDate       DateTime @default(now())
  eventType       String   // scan_started, scan_completed, page_view, etc.
  eventData       String   // JSON with event details
  metadata        String?  // JSON with additional metadata
  ipAddress       String?
  userAgent       String?
  referrer        String?
  
  @@index([userId])
  @@index([sessionId])
  @@index([eventType])
  @@index([eventDate])
}

model ScanMetrics {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  scanType        String   // github, url, linkedin, forms
  totalScans      Int      @default(0)
  completedScans  Int      @default(0)
  failedScans     Int      @default(0)
  avgScanDuration Int?     // Average scan duration in ms
  uniqueUsers     Int      @default(0) // Based on sessions or user IDs
  
  @@unique([date, scanType])
  @@index([date])
  @@index([scanType])
}

model ThreatDatabase {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  threatType      String   // malware, phishing, vulnerability, etc.
  source          String   // virustotal, github, manual, etc.
  sourceId        String   // ID from the source system
  threatData      String   // JSON with threat details
  severity        String   // low, medium, high, critical
  confidence      Int      @default(0) // 0-100 confidence score
  isActive        Boolean  @default(true)
  firstSeen       DateTime @default(now())
  lastSeen        DateTime @default(now())
  metadata        String?  // JSON with additional metadata
  
  @@index([threatType])
  @@index([source])
  @@index([severity])
  @@index([isActive])
  @@index([firstSeen])
}

model CacheEntry {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // JSON data
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  metadata    String?  // JSON with cache metadata
  
  @@index([expiresAt])
  @@index([key])
}

// Enhanced Authentication and User Management Models
model User {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  email           String   @unique
  username        String?  @unique
  firstName       String?
  lastName        String?
  passwordHash    String
  salt            String
  role            UserRole @default(USER)
  status          UserStatus @default(ACTIVE)
  emailVerified   Boolean  @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  loginCount      Int      @default(0)
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?  // TOTP secret
  backupCodes     String?  // JSON array of backup codes
  avatar          String?  // Profile picture URL
  timezone        String?  // User timezone
  language        String   @default("en")
  preferences     String?  // JSON with user preferences
  metadata        String?  // JSON with additional metadata
  
  // Relations
  sessions        UserSession[]
  apiKeys         ApiKey[]
  oauthAccounts   OAuthAccount[]
  auditLogs       AuditLog[]
  
  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model UserSession {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  sessionId       String   @unique
  refreshToken    String   @unique
  accessToken     String?  // Current access token
  ipAddress       String?
  userAgent       String?
  isActive        Boolean  @default(true)
  expiresAt       DateTime
  lastActivityAt  DateTime @default(now())
  deviceInfo      String?  // JSON with device information
  location        String?  // JSON with location data
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([sessionId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@index([isActive])
}

model ApiKey {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  name            String
  key             String   @unique
  keyPrefix       String   // First 8 characters for display
  permissions     String[] // Array of permissions
  isActive         Boolean  @default(true)
  lastUsedAt      DateTime?
  expiresAt        DateTime?
  usageCount      Int      @default(0)
  rateLimit        Int?     // Requests per hour
  metadata        String?  // JSON with additional metadata
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyUsage     ApiKeyUsage[]
  
  @@index([userId])
  @@index([key])
  @@index([keyPrefix])
  @@index([isActive])
  @@index([expiresAt])
}

model ApiKeyUsage {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  apiKeyId        String
  endpoint        String
  method          String
  ipAddress       String?
  userAgent       String?
  responseTime    Int?     // Response time in milliseconds
  statusCode      Int
  success         Boolean
  metadata        String?  // JSON with additional metadata
  
  // Relations
  apiKey          ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([success])
}

model OAuthAccount {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  provider        OAuthProvider
  providerId      String   // Provider's user ID
  providerEmail   String?
  accessToken     String?  // Encrypted
  refreshToken   String?  // Encrypted
  expiresAt       DateTime?
  scopes          String[] // Array of granted scopes
  metadata        String?  // JSON with provider-specific data
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerId])
  @@index([userId])
  @@index([provider])
}

model AuditLog {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  userId          String?
  sessionId       String?
  action          AuditAction
  resource        String?  // Resource that was acted upon
  resourceId      String?  // ID of the resource
  ipAddress       String?
  userAgent       String?
  success         Boolean
  errorMessage    String?
  metadata        String?  // JSON with additional context
  
  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([sessionId])
  @@index([action])
  @@index([createdAt])
  @@index([success])
}

model Permission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  name            String   @unique
  description     String
  resource        String   // Resource type (e.g., 'scans', 'users', 'analytics')
  action          String   // Action type (e.g., 'read', 'write', 'delete')
  isActive        Boolean  @default(true)
  
  // Relations
  rolePermissions RolePermission[]
  
  @@index([resource])
  @@index([action])
  @@index([isActive])
}

model Role {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  name            String   @unique
  displayName     String
  description     String
  isActive        Boolean  @default(true)
  isSystem        Boolean  @default(false) // System roles cannot be deleted
  
  // Relations
  rolePermissions RolePermission[]
  
  @@index([name])
  @@index([isActive])
}

model RolePermission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  roleId          String
  permissionId    String
  
  // Relations
  role            Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// Enums
enum UserRole {
  USER
  ANALYST
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum OAuthProvider {
  GITHUB
  GOOGLE
  MICROSOFT
  LINKEDIN
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_CHANGE
  MFA_ENABLED
  MFA_DISABLED
  API_KEY_CREATED
  API_KEY_DELETED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ROLE_CHANGED
  PERMISSION_GRANTED
  PERMISSION_REVOKED
  SCAN_STARTED
  SCAN_COMPLETED
  DATA_EXPORTED
  SETTINGS_UPDATED
}
