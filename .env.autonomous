# Autonomous System Production Configuration
# Copy this file to .env.local and update with your actual values

# Database Configuration
DATABASE_URL="postgresql://trusthire:your_password@localhost:5432/trusthire"
REDIS_URL="redis://localhost:6379"

# Security APIs (Required for full functionality)
VIRUSTOTAL_API_KEY="your_virustotal_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
GROQ_API_KEY="gsk_your_groq_api_key_here"
ABSTRACT_API_KEY="your_abstract_api_key_here"
APIVOID_API_KEY="your_apivoid_api_key_here"

# Application Configuration
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://trusthire.yourdomain.com"

# Autonomous System Configuration
AUTONOMY_LEVEL="full"
DECISION_THRESHOLD="0.8"
RESPONSE_SPEED="immediate"
LEARNING_RATE="adaptive"
HEALING_AGGRESSIVENESS="moderate"
COMPLIANCE_MODE="balanced"
RESOURCE_OPTIMIZATION="balanced"

# Safety Configuration
HUMAN_OVERSIGHT="true"
APPROVAL_REQUIRED="false"
ROLLBACK_ENABLED="true"
MAX_AUTONOMY_TIME="30"
EMERGENCY_STOP="true"
AUDIT_TRAIL="true"

# Monitoring Configuration
MONITORING_FREQUENCY="60"
ALERT_CHANNELS="slack,email"
RETENTION_DAYS="30"

# Performance Configuration
MAX_CONCURRENT_DECISIONS="10"
MAX_LEARNING_SESSIONS="5"
MAX_OPERATIONS="20"
DECISION_TIMEOUT="30"
LEARNING_TIMEOUT="3600"
OPERATION_TIMEOUT="1800"

# Debug Configuration
DEBUG="false"
LOG_LEVEL="info"
AUTONOMOUS_DEBUG="false"

# Decision Engine Configuration
DECISION_MODEL_TYPE="reinforcement"
DECISION_CONFIDENCE_THRESHOLD="0.7"
DECISION_MAX_CONCURRENT="10"
DECISION_HISTORY_LIMIT="1000"
DECISION_CACHE_TTL="3600"

# Self-Healing Configuration
HEALING_MONITORING_FREQUENCY="30"
HEALING_PREDICTIVE_MODE="true"
HEALING_AUTO_RECOVERY="true"
HEALING_RESOURCE_THRESHOLD="0.8"
HEALING_MAX_CONCURRENT="5"
HEALING_ROLLBACK_ENABLED="true"

# Threat Response Configuration
THREAT_RESPONSE_AUTO_CONTAINMENT="true"
THREAT_RESPONSE_AUTO_ERADICATION="false"
THREAT_RESPONSE_ESCALATION_TIMEOUT="300"
THREAT_RESPONSE_MAX_CONCURRENT="5"
THREAT_RESPONSE_INTEGRATION_ENABLED="true"

# Learning & Evolution Configuration
LEARNING_MODEL_TYPE="reinforcement"
LEARNING_TRAINING_FREQUENCY="daily"
LEARNING_IMPROVEMENT_THRESHOLD="0.05"
LEARNING_MODEL_RETENTION="30d"
LEARNING_MAX_CONCURRENT="3"
LEARNING_AUTO_RETRAIN="true"

# Operations Management Configuration
OPERATIONS_AUTO_APPROVAL="true"
OPERATIONS_COST_LIMIT="1000"
OPERATIONS_TIME_LIMIT="3600"
OPERATIONS_HUMAN_INTERVENTION_THRESHOLD="0.1"
OPERATIONS_MAX_CONCURRENT="20"

# Integration Configuration
SIEM_ENDPOINT="https://your-siem.example.com/api/v2"
SIEM_API_KEY="your_siem_api_key"
SOAR_ENDPOINT="https://your-soar.example.com/api/v1"
SOAR_API_KEY="your_soar_api_key"
TICKETING_ENDPOINT="https://your-ticketing.example.com/api/v1"
TICKETING_API_KEY="your_ticketing_api_key"

# Notification Configuration
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER="your_email@gmail.com"
EMAIL_SMTP_PASS="your_app_password"
SMS_API_KEY="your_sms_api_key"
SMS_API_URL="https://api.twilio.com/2010-04-01/Accounts"

# Security Configuration
JWT_SECRET="your_jwt_secret_key_here"
ENCRYPTION_KEY="your_encryption_key_here"
API_RATE_LIMIT="1000"
CORS_ORIGINS="https://trusthire.yourdomain.com,https://admin.trusthire.yourdomain.com"
CORS_METHODS="GET,POST,PUT,DELETE,PATCH,OPTIONS"
CORS_HEADERS="Content-Type,Authorization,X-Requested-With"

# SSL/TLS Configuration
SSL_CERT_PATH="/etc/nginx/ssl/cert.pem"
SSL_KEY_PATH="/etc/nginx/ssl/key.pem"
SSL_CA_PATH="/etc/nginx/ssl/ca.pem"
SSL_PROTOCOLS="TLSv1.2,TLSv1.3"
SSL_CIPHERS="ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384"

# Backup Configuration
BACKUP_ENABLED="true"
BACKUP_FREQUENCY="daily"
BACKUP_RETENTION="30d"
BACKUP_ENCRYPTION="true"
BACKUP_STORAGE="s3://your-backup-bucket"
BACKUP_ACCESS_KEY="your_aws_access_key"
BACKUP_SECRET_KEY="your_aws_secret_key"

# Performance Optimization
CACHE_TTL="3600"
CACHE_MAX_SIZE="1000"
COMPRESSION_ENABLED="true"
MINIFICATION_ENABLED="true"
CDN_ENABLED="true"
CDN_URL="https://cdn.trusthire.yourdomain.com"

# Scaling Configuration
AUTO_SCALING_ENABLED="true"
MIN_REPLICAS="2"
MAX_REPLICAS="10"
SCALE_UP_THRESHOLD="80"
SCALE_DOWN_THRESHOLD="20"
SCALE_UP_COOLDOWN="300"
SCALE_DOWN_COOLDOWN="300"

# Compliance Configuration
COMPLIANCE_FRAMEWORKS="gdpr,soc2,hipaa"
COMPLIANCE_AUDIT_ENABLED="true"
COMPLIANCE_DATA_RETENTION="2555d"  # 7 years
COMPLIANCE_ANONYMIZATION="true"
COMPLIANCE_ENCRYPTION="true"
COMPLIANCE_ACCESS_LOGS="true"

# Business Configuration
BUSINESS_HOURS_START="09:00"
BUSINESS_HOURS_END="17:00"
BUSINESS_TIMEZONE="UTC"
BUSINESS_HOLIDAYS="2024-01-01,2024-07-04,2024-12-25"
BUSINESS_CRITICAL_PERIODS="maintenance,deployment"

# Cost Management
COST_TRACKING_ENABLED="true"
COST_BUDGET_MONTHLY="10000"
COST_ALERT_THRESHOLD="80"
COST_OPTIMIZATION_ENABLED="true"
COST_REPORTING_FREQUENCY="weekly"

# Development/Testing Configuration
TEST_MODE="false"
MOCK_APIS="false"
SIMULATION_MODE="false"
DEBUG_DECISIONS="false"
DEBUG_HEALING="false"
DEBUG_LEARNING="false"
DEBUG_OPERATIONS="false"
