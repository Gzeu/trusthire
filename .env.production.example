# TrustHire Production Environment Variables
# Simplified for real data system - NO AI/ML DEPENDENCIES

# Database Configuration
DATABASE_URL="file:./production.db"

# API Authentication (REQUIRED FOR PRODUCTION)
API_KEY="your-production-api-key-here"

# JWT Secret (for authentication)
JWT_SECRET="your-production-jwt-secret-here"

# Next.js Configuration
NEXT_PUBLIC_BASE_URL="https://trusthire-hvaqhrlle-gzeus-projects.vercel.app"

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900000

# Security Configuration
ENCRYPTION_KEY="your-production-encryption-key-here"

# Production Environment
NODE_ENV="production"

# Redis Configuration (Optional - for caching)
# REDIS_URL="redis://your-redis-connection-string"

# Monitoring Configuration
LOG_LEVEL="info"
ENABLE_METRICS="true"

# CORS Configuration
ALLOWED_ORIGINS="https://trusthire-hvaqhrlle-gzeus-projects.vercel.app,https://localhost:3000"

# Data Processing Limits
MAX_FILE_SIZE="10MB"
MAX_RECORDS_PER_REQUEST="1000"

# Export Configuration
EXPORT_TIMEOUT="120000"
