# TrustHire Environment Variables
# Simplified for real data system - NO AI/ML DEPENDENCIES

# Database Configuration
DATABASE_URL="file:./dev.db"

# API Authentication (Optional for development)
API_KEY="your-development-api-key-here"

# JWT Secret (for authentication)
JWT_SECRET="your-development-jwt-secret-here"

# Next.js Configuration
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900000

# Security Configuration
ENCRYPTION_KEY="your-development-encryption-key-here"

# Development Environment
NODE_ENV="development"

# Data Processing Limits
MAX_FILE_SIZE="10MB"
MAX_RECORDS_PER_REQUEST="1000"

# Export Configuration
EXPORT_TIMEOUT="120000"

# Monitoring Configuration
LOG_LEVEL="debug"
ENABLE_METRICS="true"
