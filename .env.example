# Database - Turso SQLite
TURSO_DATABASE_URL="libsql://database-champagne-anchor-vercel-icfg-h5bmvex1k5x9icowny1rcosm.aws-eu-west-1.turso.io"
TURSO_AUTH_TOKEN="your_turso_auth_token_here"

# Redis Configuration (optional - for caching and sessions)
REDIS_URL="redis://localhost:6379"

# VirusTotal API (free at https://www.virustotal.com/gui/join-us)
VIRUSTOTAL_API_KEY="your_virustotal_api_key_here"

# GitHub Token (optional, increases rate limits from 60 to 5000/hour)
GITHUB_TOKEN="your_github_personal_access_token_here"

# PhishTank API (free at https://www.phishtank.com/api_info)
PHISHTANK_API_KEY="your_phishtank_api_key_here"

# MISP API (for threat intelligence integration)
MISP_URL="your_misp_instance_url"
MISP_API_KEY="your_misp_api_key_here"

# App Configuration
NEXT_PUBLIC_APP_URL="https://trusthire-five.vercel.app"
NODE_ENV="production"

# Groq AI API Key (required for AI analysis - get free at https://console.groq.com)
GROQ_API_KEY="your_groq_api_key_here"

# LangSmith API Key (optional, for LangChain monitoring and debugging)
LANGSMITH_API_KEY="your_langsmith_api_key_here"

# Admin Secret for admin routes
ADMIN_SECRET="your-secure-admin-secret-key-here"

# Abstract API for Email Validation (free tier available at https://www.abstractapi.com)
ABSTRACT_API_KEY="your_abstract_api_key_here"

# APIVoid for Domain Reputation (free tier available at https://www.apivoid.com)
APIVOID_API_KEY="your_apivoid_api_key_here"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-here-min-32-characters"
JWT_EXPIRESIN="7d"
REFRESH_TOKEN_EXPIRESIN="30d"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_MS=60000

# Security
CORS_ORIGIN="https://trusthire-five.vercel.app"
SECURITY_HEADERS_ENABLED=true
