# Database (PostgreSQL - Supabase or Railway)
DATABASE_URL="postgresql://user:password@host:5432/trusthire"

# VirusTotal API (free at https://www.virustotal.com/gui/join-us)
# Free tier: 500 req/day, 4 req/min
VIRUSTOTAL_API_KEY="your_vt_api_key_here"

# GitHub Token (optional - increases rate limits for repo scanning)
GITHUB_TOKEN="your_github_token_here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
